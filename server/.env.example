# Backend
BACKEND_PORT=3333
DATA_DIR=data
STATIC_DIR=dist

# CORS: separe multiplos dominios por virgula.
# Em producao, troque pelo seu dominio real.
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,https://app.seudominio.com

# Dados iniciais opcionais. A tela Configuracao Fiscal tambem salva esses dados em data/fiscal-config.json.
COMPANY_NAME=NOME DA EMPRESA
COMPANY_CNPJ=00000000000000
COMPANY_IE=000000000
COMPANY_CITY_CODE=2504009
COMPANY_CITY_NAME=Campina Grande
COMPANY_STATE=PB
COMPANY_TAX_REGIME=simples

# local, homologacao ou producao
NFCE_ENV=local
NFCE_CSC=
NFCE_CSC_ID=
NFCE_SERIE=1
NFCE_NEXT_NUMBER=1
