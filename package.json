{
  "name": "bicho-de-pelo---emissor-fiscal-campina-grande",
  "private": true,
  "version": "0.0.5",
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite",
    "dev:backend": "tsx watch server/index.ts",
    "dev:all": "concurrently \"npm run dev:backend\" \"npm run dev\"",
    "build": "vite build",
    "build:server": "esbuild server/index.ts --bundle --platform=node --format=esm --target=node22 --packages=external --outfile=build/server/index.js",
    "prepare:server:prod": "npm --prefix server install --omit=dev",
    "build:desktop": "npm run build && npm run build:server && npm run prepare:server:prod",
    "electron": "npm run build && electron .",
    "dist:win": "npm run build:desktop && electron-builder --win",
    "serve:local": "npm run build && npm run start",
    "preview": "vite preview",
    "backend": "tsx server/index.ts",
    "start": "tsx server/index.ts",
    "start:backend": "tsx server/index.ts"
  },
  "dependencies": {
    "@google/genai": "1.35.0",
    "@xmldom/xmldom": "^0.9.10",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "multer": "^2.1.1",
    "node-forge": "^1.4.0",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "win-ca": "^3.5.1",
    "xml-crypto": "^6.1.2"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^22.14.0",
    "@vitejs/plugin-react": "^5.0.0",
    "concurrently": "^9.2.1",
    "electron": "^42.3.0",
    "electron-builder": "^26.8.1",
    "tsx": "^4.22.4",
    "typescript": "~5.8.2",
    "vite": "^6.2.0",
    "wait-on": "^9.0.10"
  },
  "build": {
    "appId": "br.com.bichodepelo.emissor",
    "productName": "Bicho de Pelo",
    "directories": {
      "output": "release"
    },
    "files": [
      "electron/main.cjs",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "dist",
        "to": "dist"
      },
      {
        "from": "build/server",
        "to": "server"
      },
      {
        "from": "server/package.json",
        "to": "server/package.json"
      },
      {
        "from": "server/package-lock.json",
        "to": "server/package-lock.json"
      },
      {
        "from": "server/node_modules",
        "to": "server/node_modules",
        "filter": [
          "**/*",
          "!**/.cache/**",
          "!**/*.log"
        ]
      }
    ],
    "asar": true,
    "asarUnpack": [
      "server/**/*"
    ],
    "win": {
      "target": [
        "nsis",
        "portable"
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  }
}
